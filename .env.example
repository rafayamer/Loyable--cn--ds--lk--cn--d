# ── Database (Neon) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/loyable?sslmode=require

# ── Redis (Upstash) ───────────────────────────────────────────────
REDIS_URL=rediss://default:xxx@tight-jaybird-xxxxx.upstash.io:6379

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-32-chars-minimum
JWT_REFRESH_SECRET=change-me-32-chars-minimum-refresh

# ── Backend public URL (used so WAHA knows where to send webhooks) ─
API_BASE_URL=https://your-domain.com

# ── WAHA (operator-managed, tenants never see this) ───────────────
WAHA_API_KEY=change-me
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=change-me

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxx
