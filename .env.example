# ── Database (Neon) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/loyable?sslmode=require

# ── Redis (Upstash) ───────────────────────────────────────────────
REDIS_URL=rediss://default:xxx@tight-jaybird-xxxxx.upstash.io:6379

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-32-chars-minimum
JWT_REFRESH_SECRET=change-me-32-chars-minimum-refresh

# ── Backend public URL (used so WAHA knows where to send webhooks) ─
API_BASE_URL=https://your-domain.com

# ── WAHA (operator-managed, tenants never see this) ───────────────
WAHA_API_KEY=change-me
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=change-me

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxx

# ── Email (transactional: password resets, staff invites, billing) ─
# Set ONE provider. With none set, emails are logged in dev / skipped in prod.
EMAIL_FROM=hello@your-domain.com
EMAIL_FROM_NAME=Loyable
# Option A — Resend (recommended, https://resend.com)
RESEND_API_KEY=re_xxx
# Option B — SendGrid (https://sendgrid.com)
# SENDGRID_API_KEY=SG.xxx
# Option C — SMTP (requires: npm i nodemailer)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password
