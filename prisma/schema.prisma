  @@index([createdAt])
  @@map("public_reviews")
}

model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  summary    String   @db.Text
  content    String   @db.Text
  coverImage String?
  published  Boolean  @default(false)
  tags       Json     @default("[]")
  seoTitle   String?
  seoDesc    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@map("blog_posts")
}

model FaqItem {
