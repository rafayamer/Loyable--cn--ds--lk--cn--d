  question  String   @db.Text
  answer    String   @db.Text
  order     Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  @@map("faq_items")
}

model AnnouncementBanner {
  id       String    @id @default(cuid())
  text     String    @db.Text
  linkText String?
  linkUrl  String?
  type     String    @default("INFO")
  active   Boolean   @default(true)
  startsAt DateTime?
  endsAt   DateTime?
  createdAt DateTime @default(now())
  @@map("announcement_banners")
}

model WebsitePageView {
  id        String   @id @default(cuid())
  page      String
  event     String   @default("PAGE_VIEW")
  referer   String?
  ipHash    String?
  createdAt DateTime @default(now())
  @@index([page, createdAt])
  @@map("website_page_views")
}

model PortalLogin {
  id         String   @id @default(cuid())
  customerId String
  businessId String
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([customerId])
  @@map("portal_logins")
}

model FeedbackResponse {
  id         String   @id @default(cuid())
  businessId String
  customerId String
  visitId    String?
  score      Int      // 1–5 star rating from WhatsApp quick-reply
  comment    String?  // Optional follow-up message
  channel    String   @default("WHATSAPP") // WHATSAPP | SMS | EMAIL
  sentAt     DateTime // When the rating request was sent
  createdAt  DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([customerId])
  @@index([businessId, score])
  @@map("feedback_responses")
}

model WhatsAppMessage {
  id         String   @id @default(cuid())
  businessId String
  chatId     String   // e.g. "923001234567@s.whatsapp.net"
  phone      String   // normalised "+923001234567"
  body       String   @default("")
  fromMe     Boolean  @default(false)
  timestamp  DateTime @default(now())
  msgId      String?  // Baileys message key id (for dedup)
  mediaType  String?  // "image" | "video" | "audio" | "document" | null
  customerId String?  // resolved FK if customer exists

  @@unique([businessId, msgId])
  @@index([businessId, chatId, timestamp])
  @@index([businessId, timestamp])
  @@map("whatsapp_messages")
}
