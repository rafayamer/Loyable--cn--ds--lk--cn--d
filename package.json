{
  "name": "cube-retain-crm-api",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS Customer Retention Platform — Cube Retain CRM",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "dev:all": "concurrently --names \"api,vite,waha\" \"npm run dev\" \"npm --prefix client run dev\" \"npm run waha:dev\"",
    "dev:no-waha": "concurrently --names \"api,vite\" \"npm run dev\" \"npm --prefix client run dev\"",
    "client:dev": "npm --prefix client run dev",
    "admin:dev": "npm --prefix client run admin",
    "client:build": "cd client && npm run build",
    "client:install": "cd client && npm install",
    "waha:install": "cd waha && yarn install",
    "waha:dev": "cd waha && PORT=3001 WHATSAPP_API_PORT=3001 WAHA_API_KEY=loyable WAHA_DASHBOARD_USERNAME=admin WAHA_DASHBOARD_PASSWORD=loyable WHATSAPP_SWAGGER_USERNAME=admin WHATSAPP_SWAGGER_PASSWORD=loyable WHATSAPP_DEFAULT_ENGINE=NOWEB WAHA_PRINT_QR=false WAHA_LOG_FORMAT=PRETTY WHATSAPP_RESTART_ALL_SESSIONS=false yarn start:dev",
    "waha:build": "cd waha && yarn build",
    "db:fix-waha": "ts-node scripts/fix-waha-session.ts",
    "build": "tsc --project tsconfig.json && npm run client:build",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "db:validate": "prisma validate",
    "typecheck": "tsc --noEmit",
    "fresh": "bash scripts/fresh-dev.sh"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "argon2": "^0.31.2",
    "axios": "^1.6.8",
    "bullmq": "^5.7.8",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "redis": "^5.0.0",
    "stripe": "^15.7.0",
    "zod": "^3.23.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.43",
    "@types/node-cron": "^3.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
